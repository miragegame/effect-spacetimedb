 // Strict scalar compare for index term values.
+const tableCacheComparableBigIntKeys = [
+  '__connection_id__',
+  '__identity__',
+  '__time_duration_micros__',
+  '__timestamp_micros_since_unix_epoch__',
+  '__uuid__',
+] as const;
+
+const toTableCacheComparableValue = (value: any): any => {
+  if (value instanceof Uint8Array) {
+    return Array.from(value, byte =>
+      byte.toString(16).padStart(2, '0')
+    ).join('');
+  }
+  if (value && typeof value === 'object') {
+    for (const key of tableCacheComparableBigIntKeys) {
+      const candidate = value[key];
+      if (typeof candidate === 'bigint') return candidate;
+    }
+    if (typeof value.toHexString === 'function') return value.toHexString();
+  }
+  return value;
+};
+
 const scalarCompare = (x: any, y: any): number => {
-  if (x === y) return 0;
+  const comparableX = toTableCacheComparableValue(x);
+  const comparableY = toTableCacheComparableValue(y);
+  if (comparableX === comparableY) return 0;
   // Compare booleans/numbers/bigints/strings with JS ordering.
-  return x < y ? -1 : 1;
+  return comparableX < comparableY ? -1 : 1;
 };
