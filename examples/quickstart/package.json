{
  "name": "effect-spacetimedb-example-quickstart",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "spacetime build --module-path .",
    "generate-client": "spacetime generate --lang typescript --js-path ./dist/bundle.js --out-dir ./src/generated --yes",
    "smoke:client-import": "bun -e 'await import(\"./src/client.ts\")'",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "effect": "4.0.0-beta.93",
    "effect-spacetimedb": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "typescript": "5.9.3"
  }
}
