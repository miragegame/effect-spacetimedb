{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist-types",
    "outDir": "dist-types",
    "tsBuildInfoFile": "dist-types/tsconfig.tsbuildinfo",
    "incremental": true,
    "noEmit": false
  },
  "references": [
    {
      "path": "../../packages/effect-spacetimedb/tsconfig.build.json"
    }
  ],
  "exclude": ["dist-types", "**/dist-types"]
}
