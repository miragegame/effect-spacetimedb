---
import Search from "@astrojs/starlight/components/Search.astro"
import Logo from "./Logo.astro"

interface Props {
  marketing?: boolean
}

const { marketing = false } = Astro.props
---

<nav class:list={["site-nav", { "site-nav--docs": !marketing }]}>
  <a href="/" class="site-nav__brand" aria-label="Effect SpacetimeDB home">
    <Logo />
  </a>
  <div class="site-nav__spacer"></div>
  <div class="site-nav__search">
    <Search />
  </div>
  <a href="/getting-started" class="site-nav__link">Docs</a>
  <a href="/reference" class="site-nav__link">Reference</a>
  <a
    href="https://github.com/miragegame/effect-spacetimedb"
    class="site-nav__link site-nav__link--icon"
    aria-label="GitHub"
  >
    <svg aria-hidden width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.04 11.04 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.19 0 .31.21.67.8.56C20.71 21.39 24 17.08 24 12 24 5.73 18.27.5 12 .5z"></path>
    </svg>
    <span>GitHub</span>
  </a>
</nav>

<style>
  .site-nav,
  .site-nav * {
    box-sizing: border-box;
  }
  .site-nav {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .site-nav__brand {
    color: inherit;
    text-decoration: none;
    flex-shrink: 0;
  }
  .site-nav__spacer {
    flex: 1;
  }
  .site-nav__link {
    color: var(--site-n2);
    font-family: var(--site-font-mono);
    font-size: 11.7px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    line-height: 1;
    border-radius: 4px;
    padding: 8px 16px;
    transition:
      color 0.2s,
      background 0.2s;
  }
  .site-nav__link:hover {
    background: var(--site-shade-4);
    color: var(--site-n1);
  }
  .site-nav__link--icon {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .site-nav__search {
    width: 230px;
    margin-right: 8px;
  }
  .site-nav__search :global(button[data-open-modal]) {
    border-radius: 6px;
    border-color: var(--site-border);
    background: var(--site-surface);
    color: var(--site-text-muted);
    font-family: var(--site-font-mono);
    font-size: 11.7px;
    line-height: 1.75;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .site-nav__search :global(kbd.sl-hidden) {
    display: flex;
    font-size: 12px;
    line-height: 21px;
  }
  @media (max-width: 820px) {
    .site-nav__search {
      display: none;
    }
  }
  @media (max-width: 620px) {
    .site-nav {
      gap: 4px;
    }
    .site-nav__link {
      padding-inline: 10px;
    }
    .site-nav__link--icon span {
      display: none;
    }
  }
  @media (max-width: 430px) {
    .site-nav__link[href="/reference"] {
      display: none;
    }
  }
</style>
