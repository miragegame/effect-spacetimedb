{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "astro/tsconfigs/strict",
  "include": ["src/**/*", ".astro/*.d.ts"],
  "compilerOptions": {
    "noEmit": true,
    "types": ["astro/client"],
    "jsx": "preserve",
    "jsxImportSource": "react",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
