{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.dist.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "dist-types",
    "test/**",
    "**/*.test.ts",
    "examples/**",
    "scripts/**",
    "vitest*.ts"
  ]
}
